# Supabase — obrigatório para o sistema funcionar
# Encontre esses valores em: Project Settings > API do seu projeto Supabase
VITE_SUPABASE_URL="https://SEU_PROJETO.supabase.co"
VITE_SUPABASE_ANON_KEY="sua_anon_key_aqui"

# Google Gemini (opcional - para funcionalidades de IA futuras)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# MaxBank — Área do Cliente / Modo Visitante
# Quando preenchidos, os QRs de PIX e Cartão do PDV apontam para a
# Área do Cliente pública do MaxBank (https://<host>/pagar/<branch>/<uuid>
# e /pagar-cartao/...), permitindo alunos externos pagarem sem cadastro.
# Vazios => fallback para o payload antigo MAX-PIX-<uuid>/MAX-CARTAO-<uuid>
# (só é lido pelo app MaxBank instalado no operador logado).
VITE_MAXBANK_URL=""
VITE_MAXBANK_BRANCH_ID=""
